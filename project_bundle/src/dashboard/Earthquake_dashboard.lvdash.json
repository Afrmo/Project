{
  "datasets": [
    {
      "name": "a856af15",
      "displayName": "Earthquake_details",
      "queryLines": [
        "select * from dev.sliver.earthwuake_data_final"
      ]
    },
    {
      "name": "eacf03d6",
      "displayName": "Earthquake_type",
      "queryLines": [
        "select\r\n",
        "count(*) as total_magnitude_bucket,\r\n",
        "magnitude_bucket\r\n",
        "         from \r\n",
        "        (select CASE\r\n",
        "        WHEN mag < 2 THEN 'Micro (<2)'\r\n",
        "        WHEN mag BETWEEN 2 AND 3 THEN 'Minor (2–3)'\r\n",
        "        WHEN mag BETWEEN 3 AND 4 THEN 'Light (3–4)'\r\n",
        "        ELSE 'Moderate+ (4+)'\r\n",
        "        END AS magnitude_bucket\r\n",
        "        from dev.sliver.earthwuake_data_final)\r\n",
        " group by magnitude_bucket"
      ],
      "catalog": "dev",
      "schema": "sliver"
    },
    {
      "name": "92cc1e1d",
      "displayName": "Earthquake_country",
      "queryLines": [
        "SELECT\r\n",
        "  count(*) AS event_count,\r\n",
        "  CASE\r\n",
        "    WHEN size(split(place, ', ')) = 1 THEN split(place, ', ')[0]\r\n",
        "    ELSE split(place, ', ')[1]\r\n",
        "  END AS country\r\n",
        "FROM\r\n",
        "  dev.sliver.earthwuake_data_final\r\n",
        "GROUP BY\r\n",
        "  country"
      ]
    }
  ],
